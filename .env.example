# .env.example
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env a GitHub.

# --- Django ---
SECRET_KEY=tu-clave-secreta-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de datos PostgreSQL ---
POSTGRES_DB=clinica_solaz
POSTGRES_USER=clinica_user
POSTGRES_PASSWORD=tu-contraseña-aqui
DATABASE_URL=postgres://clinica_user:tu-contraseña-aqui@db:5432/clinica_solaz

# --- Django: zona horaria ---
TIME_ZONE=Europe/Madrid